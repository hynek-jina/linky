{
  "name": "linky",
  "private": true,
  "version": "26.1.0",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @linky/web-app dev",
    "build": "bun run --filter @linky/web-app build",
    "preview": "bun run --filter @linky/web-app preview",
    "native:android:add": "bun run --filter @linky/native-shell android:add",
    "native:android:sync": "bun run --filter @linky/native-shell android:sync",
    "native:android:open": "bun run --filter @linky/native-shell android:open",
    "native:apk:debug": "bun run --filter @linky/native-shell android:apk:debug",
    "native:ios:add": "bun run --filter @linky/native-shell ios:add",
    "native:ios:sync": "bun run --filter @linky/native-shell ios:sync",
    "native:ios:open": "bun run --filter @linky/native-shell ios:open",
    "push:dev": "bun run --filter @linky/push dev",
    "push:start": "bun run --filter @linky/push start",
    "eslint": "bun run --workspaces --if-present eslint",
    "prettier": "bun run --workspaces --if-present prettier",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "check-code": "bun run typecheck && bun run eslint && bun run prettier"
  }
}
