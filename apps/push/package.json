    "nostr-tools": "^2.23.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@linky/config": "workspace:*",
    "@types/bun": "^1.3.2",
    "@types/node": "^24.10.1",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.39.1",
    "prettier": "^3.4.2",
    "typescript": "~5.9.3"
  }
}
